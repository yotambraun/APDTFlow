---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Button from '../components/Button.astro';
import { docs, site, url } from '../data/site';

const topics = [
  {
    title: 'What we tested and rejected',
    body: 'ODE-RNN encoders and explicit missingness features both lost to simple imputation baselines. We document the negative results instead of hiding them.',
    href: docs.methodology,
    link: 'docs/METHODOLOGY.md',
  },
  {
    title: 'The v0.4.0 critical fix',
    body: 'Versions ≤ 0.3.x contained a defect that made predictions independent of the input series. All pre-0.4 checkpoints are invalid; the regression is now guarded by a test.',
    href: docs.changelog,
    link: 'CHANGELOG.md',
  },
  {
    title: 'Model architectures',
    body: 'Neural ODE (default), Transformer, TCN, and Ensemble decoders; the continuous-time decoder and the asymmetric, time-space conformal calibration behind predict_when.',
    href: docs.models,
    link: 'docs/models.md',
  },
];
---

<BaseLayout
  title="Methodology"
  description="How APDTFlow is built and evaluated — including the ideas we tested and rejected."
>
  <PageHeader
    eyebrow="How it works, honestly"
    title="Methodology"
    intro="The deep technical record lives in the repo so there is a single source of truth. This page points you to the right document."
  />

  <div class="wrap pb-16">
    <div class="grid gap-5 md:grid-cols-3">
      {
        topics.map((t) => (
          <a href={t.href} class="card group flex flex-col p-6 transition-all hover:border-cyan/40">
            <h2 class="text-lg font-semibold text-ink">{t.title}</h2>
            <p class="mt-2 flex-1 text-sm text-muted">{t.body}</p>
            <span class="mt-4 font-mono text-xs text-cyan group-hover:underline">{t.link} →</span>
          </a>
        ))
      }
    </div>

    <div class="mt-12 rounded-2xl border border-cyan/30 bg-cyan/5 p-6 sm:p-8">
      <h2 class="text-xl font-semibold">The story behind the rebuild</h2>
      <p class="mt-3 max-w-3xl text-muted">
        A user opened an issue asking for evidence. Auditing it revealed the model had been
        ignoring its inputs entirely. v0.4.0 is the rebuilt version: what survived hostile
        testing, and what didn't. Honesty about limits is the design, not an afterthought —
        the same reason the benchmarks show the FD002 loss.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <Button href={url('evidence')} variant="primary">See the measured evidence</Button>
        <Button href={site.repo} variant="secondary" external>Read the full docs on GitHub</Button>
      </div>
    </div>
  </div>
</BaseLayout>
