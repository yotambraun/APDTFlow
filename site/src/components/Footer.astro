---
import { site, docs, articles, url, img } from '../data/site';
const year = 2026;
---

<footer class="mt-24 border-t border-line bg-surface/40">
  <div class="wrap grid gap-10 py-14 md:grid-cols-4">
    <div class="md:col-span-1">
      <img src={img('logo_dark.png')} alt="APDTFlow" class="h-8 w-auto" />
      <p class="mt-3 max-w-xs text-sm text-muted">
        Continuous-time forecasting with Neural ODEs. Know <span class="text-ink">when</span>,
        not just what.
      </p>
    </div>

    <div>
      <h3 class="eyebrow mb-3">Docs</h3>
      <ul class="space-y-2 text-sm">
        <li><a class="text-muted hover:text-ink" href={url('quickstart')}>Quickstart</a></li>
        <li><a class="text-muted hover:text-ink" href={url('demos')}>Demos</a></li>
        <li><a class="text-muted hover:text-ink" href={url('evidence')}>Evidence</a></li>
        <li><a class="text-muted hover:text-ink" href={docs.methodology}>Methodology</a></li>
      </ul>
    </div>

    <div>
      <h3 class="eyebrow mb-3">Project</h3>
      <ul class="space-y-2 text-sm">
        <li><a class="text-muted hover:text-ink" href={site.repo}>GitHub</a></li>
        <li><a class="text-muted hover:text-ink" href={site.pypi}>PyPI</a></li>
        <li><a class="text-muted hover:text-ink" href={site.colab}>Colab notebook</a></li>
        <li><a class="text-muted hover:text-ink" href={docs.changelog}>Changelog</a></li>
      </ul>
    </div>

    <div>
      <h3 class="eyebrow mb-3">Articles</h3>
      <ul class="space-y-2 text-sm">
        {
          articles.map((a) => (
            <li>
              <a class="text-muted hover:text-ink" href={a.href}>
                {a.title} <span class="text-line">·</span> {a.outlet}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="wrap flex flex-col items-start justify-between gap-3 border-t border-line py-6 text-xs text-muted sm:flex-row sm:items-center">
    <span class="font-mono">MIT © {year} {site.author} · v{site.version}</span>
    <details class="group">
      <summary class="cursor-pointer font-mono hover:text-ink">cite this</summary>
      <pre class="mt-3 max-w-2xl overflow-x-auto rounded-lg border border-line bg-bg p-4 text-[11px] leading-relaxed text-muted"><code>@software&#123;apdtflow,
  author  = &#123;Braun, Yotam&#125;,
  title   = &#123;APDTFlow: continuous-time forecasting with Neural ODEs&#125;,
  url     = &#123;https://github.com/yotambraun/APDTFlow&#125;,
  year    = &#123;2026&#125;,
  version = &#123;0.4.0&#125;
&#125;</code></pre>
    </details>
  </div>
</footer>
