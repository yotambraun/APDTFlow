---
import { img, url } from '../data/site';

const demos = [
  {
    image: 'apdtflow_fleet_dashboard.png',
    title: 'Fleet scheduling in one call',
    body: 'predict_when_fleet() turns real NASA jet engines (never seen in training) into a maintenance schedule sorted by act-by date. In this measured snapshot the calibrated windows covered 81% of the actual crossings.',
    api: 'predict_when_fleet(assets, threshold, direction)',
  },
  {
    image: 'predict_when_demo.png',
    title: 'A calibrated answer to "when?"',
    body: 'Windows are calibrated on crossing-time errors (time space), not value bands — the distinction that makes the coverage hold. The act_by edge lands before the true crossing.',
    api: "predict_when(threshold=80, direction='above')",
  },
  {
    image: 'predict_at_demo.png',
    title: 'Forecast at any moment in time',
    body: 'One trained model, queried at arbitrary real-valued timestamps — fractional steps, between observations, even beyond the trained horizon — because the decoder integrates a continuous-time ODE.',
    api: "predict_at(['2026-06-14 14:37', 3.6])",
  },
];
---

<section class="wrap py-16">
  <div class="mb-10 max-w-2xl">
    <p class="eyebrow mb-3">See it work</p>
    <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Real data, real plots</h2>
    <p class="mt-3 text-muted">
      Every figure below is produced by a committed script on real NASA and public
      datasets. Open the <a href={url('demos')} class="text-cyan hover:underline">demos page</a>
      for the code.
    </p>
  </div>

  <div class="grid gap-6 lg:grid-cols-3">
    {
      demos.map((d) => (
        <a href={url('demos')} class="card group overflow-hidden transition-all hover:border-cyan/40 hover:shadow-glow">
          <div class="overflow-hidden border-b border-line bg-bg">
            <img
              src={img(d.image)}
              alt={d.title}
              loading="lazy"
              class="aspect-[16/11] w-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.03]"
            />
          </div>
          <div class="p-5">
            <h3 class="font-semibold text-ink">{d.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{d.body}</p>
            <code class="mt-3 block truncate font-mono text-xs text-cyan">{d.api}</code>
          </div>
        </a>
      ))
    }
  </div>
</section>
