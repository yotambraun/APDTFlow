---
// Animated, dependency-free forecast visual. All data is synthetic and baked in
// (no torch, no chart lib). It illustrates predict_when: a rising forecast that
// crosses a threshold, with a widening 90% window and an act_by edge.
//
// Geometry in a 0..600 x 0..340 viewBox. y grows downward, so higher value = lower y.
---

<div class="relative">
  <!-- background glow -->
  <div
    class="pointer-events-none absolute inset-0 -z-10 bg-hero-glow blur-2xl"
    aria-hidden="true"
  >
  </div>

  <svg
    viewBox="0 0 600 340"
    class="hero-svg w-full"
    role="img"
    aria-label="A forecast line rising to cross a maintenance threshold, with a calibrated 90% crossing-time window and an act-by edge."
  >
    <defs>
      <linearGradient id="line-grad" x1="0" y1="0" x2="600" y2="0" gradientUnits="userSpaceOnUse">
        <stop offset="0" stop-color="#22d3ee" />
        <stop offset="1" stop-color="#34d399" />
      </linearGradient>
      <linearGradient id="band-grad" x1="0" y1="0" x2="0" y2="340" gradientUnits="userSpaceOnUse">
        <stop offset="0" stop-color="#22d3ee" stop-opacity="0.16" />
        <stop offset="1" stop-color="#34d399" stop-opacity="0.04" />
      </linearGradient>
      <filter id="soft-glow" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="4" result="b" />
        <feMerge>
          <feMergeNode in="b" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>

    <!-- grid baseline -->
    <line x1="40" y1="300" x2="580" y2="300" stroke="#1c2740" stroke-width="1" />
    <line x1="40" y1="40" x2="40" y2="300" stroke="#1c2740" stroke-width="1" />

    <!-- "now" divider between history and forecast -->
    <line x1="300" y1="40" x2="300" y2="300" stroke="#1c2740" stroke-width="1" stroke-dasharray="2 5" />
    <text x="300" y="320" fill="#8aa0bd" font-size="11" font-family="JetBrains Mono, monospace" text-anchor="middle">now</text>

    <!-- threshold -->
    <line x1="40" y1="120" x2="580" y2="120" stroke="#fb7185" stroke-width="1.5" stroke-dasharray="5 5" opacity="0.7" />
    <text x="48" y="113" fill="#fb7185" font-size="11" font-family="JetBrains Mono, monospace">threshold</text>

    <!-- calibrated 90% window band (forecast half only) -->
    <path
      class="band"
      d="M300,232 L420,150 L520,70 L520,150 L420,210 L300,248 Z"
      fill="url(#band-grad)"
      stroke="#22d3ee"
      stroke-opacity="0.25"
      stroke-width="1"
    />

    <!-- history polyline (left, muted) -->
    <polyline
      points="40,250 80,244 120,252 160,240 200,246 240,238 280,242 300,240"
      fill="none"
      stroke="#5b6c8a"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    />

    <!-- forecast path (animated draw-on) -->
    <path
      class="forecast"
      d="M300,240 C340,212 372,176 410,150 C448,124 480,96 520,72"
      fill="none"
      stroke="url(#line-grad)"
      stroke-width="3.5"
      stroke-linecap="round"
      filter="url(#soft-glow)"
    />

    <!-- act_by edge: earliest plausible crossing (window's early edge meets threshold) -->
    <g class="actby">
      <line x1="392" y1="120" x2="392" y2="300" stroke="#34d399" stroke-width="1.5" stroke-dasharray="3 4" opacity="0.8" />
      <circle cx="392" cy="120" r="4" fill="#34d399" />
      <text x="386" y="335" fill="#34d399" font-size="11" font-family="JetBrains Mono, monospace" text-anchor="middle">act_by</text>
    </g>

    <!-- eta crossing marker (point estimate meets threshold) -->
    <g class="eta">
      <circle class="pulse" cx="432" cy="120" r="7" fill="#22d3ee" fill-opacity="0.25" />
      <circle cx="432" cy="120" r="4.5" fill="#22d3ee" />
      <text x="440" y="112" fill="#22d3ee" font-size="11" font-family="JetBrains Mono, monospace">eta</text>
    </g>
  </svg>
</div>

<style>
  .hero-svg {
    overflow: visible;
  }
  /* draw-on the forecast line */
  .forecast {
    stroke-dasharray: 360;
    stroke-dashoffset: 360;
    animation: draw 1.8s ease-out 0.2s forwards;
  }
  /* fade-in the uncertainty band, act_by, eta after the line draws */
  .band {
    opacity: 0;
    animation: fade 0.9s ease-out 1.4s forwards;
  }
  .actby,
  .eta {
    opacity: 0;
    animation: fade 0.7s ease-out 1.9s forwards;
  }
  .pulse {
    transform-box: fill-box;
    transform-origin: center;
    animation: pulse 2.2s ease-in-out 2.4s infinite;
  }
  @keyframes draw {
    to {
      stroke-dashoffset: 0;
    }
  }
  @keyframes fade {
    to {
      opacity: 1;
    }
  }
  @keyframes pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.25;
    }
    50% {
      transform: scale(1.9);
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .forecast {
      stroke-dashoffset: 0;
      animation: none;
    }
    .band,
    .actby,
    .eta {
      opacity: 1;
      animation: none;
    }
    .pulse {
      animation: none;
    }
  }
</style>
